# Viewing Assist Kit 环境变量配置
# 复制此文件为 .env 并填入实际值

# ========================================
# 网络配置
# ========================================

# 宿主机 IP
HOST_IP=192.168.1.100

# 内网域名后缀
DOMAIN=home.local

# Docker 网络子网
NETWORK_SUBNET=172.30.0.0/16

# ========================================
# 服务 IP (按需分配，保持唯一)
# ========================================

CADDY_IP=172.30.0.11
MIHOMO_IP=172.30.0.2
METACUBEXD_IP=172.30.0.3
HOMEPAGE_IP=172.30.0.4
JELLYFIN_IP=172.30.0.5
RADARR_IP=172.30.0.6
SONARR_IP=172.30.0.7
PROWLARR_IP=172.30.0.8
TRANSMISSION_IP=172.30.0.9
JELLYSEERR_IP=172.30.0.10

# ========================================
# 服务账户
# ========================================

# Transmission
TRANSMISSION_USERNAME=admin
TRANSMISSION_PASSWORD=your_password_here

# ========================================
# 其他配置
# ========================================

# 时区
TZ=Asia/Shanghai

# OpenClaw Gateway 端口
OPENCLAW_PORT=18789
