# Viewing Assist Kit 环境变量配置
# 使用 ./scripts/deploy.sh 自动生成，或手动复制此文件为 .env 并填入实际值

# ========================================
# 网络配置
# ========================================

# 宿主机 IP
HOST_IP=192.168.1.100

# 内网域名后缀
DOMAIN=home.local

# ========================================
# 服务账户
# ========================================

# Transmission
TRANSMISSION_USERNAME=admin
TRANSMISSION_PASSWORD=your_password_here

# ========================================
# 数据目录
# ========================================

DATA_DIR=/srv/media

# ========================================
# 用户权限
# ========================================

# 运行用户 UID/GID（默认 1000:1000，建议使用普通用户）
PUID=1000
PGID=1000

# ========================================
# 其他配置
# ========================================

# 时区
TZ=Asia/Shanghai

# OpenClaw Gateway 端口
OPENCLAW_PORT=18789
