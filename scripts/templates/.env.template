TRANSMISSION_USERNAME=admin
TRANSMISSION_PASSWORD={{TRANSMISSION_PASSWORD}}

# ========================================
# 数据目录
# ========================================

DATA_DIR={{DATA_DIR}}

# ========================================
# 用户权限
# ========================================

PUID={{PUID}}
PGID={{PGID}}

# ========================================
# 其他配置
# ========================================

# 时区
TZ={{TZ}}
