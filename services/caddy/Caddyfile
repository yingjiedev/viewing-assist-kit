{
	auto_https disable_redirects
	default_sni lb.{$DOMAIN}
}

# HTTP → HTTPS 跳转
http:// {
	redir https://{host}{uri} permanent
}

# 默认内部站点（用于 SNI-less 客户端）
https://lb.{$DOMAIN} {
	tls internal
	reverse_proxy {$HOST_IP}:{$OPENCLAW_PORT}
}

# OpenClaw Dashboard
https://openclaw.{$DOMAIN},
https://{$HOST_IP} {
	tls internal
	reverse_proxy {$HOST_IP}:{$OPENCLAW_PORT}
}

# Jellyfin
https://jellyfin.{$DOMAIN} {
	tls internal
	reverse_proxy jellyfin:8096
}

# Sonarr
https://sonarr.{$DOMAIN} {
	tls internal
	reverse_proxy sonarr:8989
}

# Radarr
https://radarr.{$DOMAIN} {
	tls internal
	reverse_proxy radarr:7878
}

# Prowlarr
https://prowlarr.{$DOMAIN} {
	tls internal
	reverse_proxy prowlarr:9696
}

# Transmission
https://transmission.{$DOMAIN} {
	tls internal
	reverse_proxy transmission:9091
}

# Jellyseerr
https://jellyseerr.{$DOMAIN} {
	tls internal
	reverse_proxy jellyseerr:5055
}

# Homepage
https://homepage.{$DOMAIN} {
	tls internal
	reverse_proxy homepage:3000
}


