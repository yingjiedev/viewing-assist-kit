{
	auto_https disable_redirects
	default_sni lb.lan.xyz
}

# HTTP → HTTPS 跳转
http:// {
	redir https://{host}{uri} permanent
}

# 默认内部站点（用于 SNI-less 客户端）
https://lb.lan.xyz {
	tls internal
	reverse_proxy {$HOST_IP:18789}
}

# OpenClaw Dashboard
https://openclaw.lan.xyz,
https://{$HOST_IP} {
	tls internal
	reverse_proxy {$HOST_IP:18789}
}

